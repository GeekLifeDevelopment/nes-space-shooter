{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build NES",
      "type": "shell",
      "command": "ca65",
      "args": [
        "src/main.s",
        "-o",
        "build/main.o"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Link NES",
      "type": "shell",
      "command": "ld65",
      "args": [
        "build/main.o",
        "-C",
        "cfg/nes.cfg",
        "-o",
        "out/game.nes"
      ],
      "dependsOn": "Build NES",
      "problemMatcher": []
    },
    {
      "label": "Build ROM",
      "dependsOn": "Link NES",
      "dependsOrder": "sequence",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}